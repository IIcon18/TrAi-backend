# =============================================================================
# TrAi Backend — шаблон переменных окружения
# Скопируйте этот файл в .env и заполните реальными значениями.
# НИКОГДА не коммитьте .env в репозиторий.
# =============================================================================

# --- База данных (PostgreSQL) -------------------------------------------------
DATABASE_URL=postgresql+asyncpg://trai_user:CHANGE_ME@db:5432/trai_db
POSTGRES_USER=trai_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=trai_db

# --- JWT Авторизация ----------------------------------------------------------
SECRET_KEY=CHANGE_ME_USE_RANDOM_64_CHARS
REFRESH_SECRET_KEY=CHANGE_ME_USE_ANOTHER_RANDOM_64_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- MinIO (объектное хранилище) ---------------------------------------------
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=trai-attachments
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_ROOT_USER=CHANGE_ME
MINIO_ROOT_PASSWORD=CHANGE_ME

# --- Redis (кеш) -------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# --- CORS --------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- URLs --------------------------------------------------------------------
FRONTEND_BASE_URL=http://localhost:3000
REACT_APP_API_URL=http://localhost:8000
REACT_APP_BASE_URL=http://localhost:3000
OPENFOODFACTS_BASE_URL=https://world.openfoodfacts.org

# --- Инициализация БД --------------------------------------------------------
# true — сбросить и пересоздать таблицы при старте (только для разработки!)
RESET_DATABASE=false
